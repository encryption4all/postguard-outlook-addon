{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "module": "esnext",
    "noEmitOnError": true,
    "outDir": "lib",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2020",
    "lib": ["es2022", "dom"],
    "types": ["office-js", "office-runtime"]
  },
  "exclude": ["node_modules", "dist", "lib", "lib-amd"]
}
