{
  "name": "postguard-outlook-addin",
  "version": "0.1.6",
  "private": true,
  "description": "PostGuard end-to-end email encryption for Outlook (new Outlook on Windows + macOS).",
  "license": "MIT",
  "config": {
    "app_to_debug": "outlook",
    "app_type_to_debug": "desktop",
    "dev_server_port": 3000
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "dev-server": "webpack serve --mode development",
    "lint": "office-addin-lint check",
    "lint:fix": "office-addin-lint fix",
    "prettier": "office-addin-lint prettier",
    "signin": "office-addin-dev-settings m365-account login",
    "signout": "office-addin-dev-settings m365-account logout",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "watch": "webpack --mode development --watch"
  },
  "dependencies": {
    "@e4a/pg-js": "^1.3.0",
    "core-js": "^3.49.0",
    "regenerator-runtime": "^0.14.1"
  },
  "overrides": {
    "strip-bom": "^4.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/office-js": "^1.0.589",
    "@types/office-runtime": "^1.0.36",
    "babel-loader": "^10.1.1",
    "copy-webpack-plugin": "^14.0.0",
    "dotenv": "^16.6.1",
    "eslint-plugin-office-addins": "^4.0.8",
    "file-loader": "^6.2.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.7",
    "office-addin-cli": "^2.0.8",
    "office-addin-debugging": "^6.1.0",
    "office-addin-dev-certs": "^2.0.8",
    "office-addin-lint": "^3.0.8",
    "office-addin-manifest": "^2.1.4",
    "office-addin-prettier-config": "^2.0.3",
    "os-browserify": "^0.3.0",
    "process": "^0.11.10",
    "source-map-loader": "^5.0.0",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "prettier": "office-addin-prettier-config",
  "browserslist": [
    "last 2 Edge versions",
    "last 2 Safari versions",
    "last 2 Chrome versions",
    "last 2 Firefox versions"
  ]
}
